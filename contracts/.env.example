# ── Deployer ──────────────────────────────────────────────────────────────────
# Private key de la billetera que hace el deploy (debe tener BNB para gas)
# Formato: 0x seguido de 64 caracteres hexadecimales
DEPLOYER_PRIVATE_KEY=0x...

# ── APIs ──────────────────────────────────────────────────────────────────────
# API key de BscScan para verificar contratos públicamente
BSCSCAN_API_KEY=

# ── Treasury ──────────────────────────────────────────────────────────────────
# Wallet que recibe los fees flat en BNB de cada burn
TREASURY_ADDRESS=0x...

# ── Distribución del supply ───────────────────────────────────────────────────
# Wallet conectada a PinkSale donde van los 200M de la preventa
PRESALE_WALLET=0x...

# Wallet que agrega liquidez en PancakeSwap (110M RCY + BNB)
LIQUIDITY_WALLET=0x...

# Wallet de marketing y partnerships (120M RCY)
MARKETING_WALLET=0x...

# Wallet de reserva del protocolo — idealmente el Multisig (80M RCY)
RESERVE_WALLET=0x...

# Wallet donde van los BNB de recompensas a holders (25% de cada venta del vault)
HOLDERS_WALLET=0x...

# Wallet de desarrollo/equipo que recibe BNB operativo (15% de cada venta del vault)
DEV_WALLET=0x...

# ── Founders (MilestoneVesting) ────────────────────────────────────────────────
# Las 3 wallets de los fundadores que reciben los 150M bloqueados por hitos
# Si son menos o más de 3, editar el script deploy.ts directamente
FOUNDER_1=0x...
FOUNDER_2=0x...
FOUNDER_3=0x...
