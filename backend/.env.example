PORT=3001

# RPC URL — accepts http(s):// or ws(s)://. Prefer WebSocket (ws/wss) for
# event subscriptions: HTTP polling triggers a known crash in
# ethers v6 FilterIdEventSubscriber against Hardhat.
# Local Hardhat:    ws://127.0.0.1:8545
# BSC Mainnet WS:   wss://bsc-ws-node.nariox.org:443
# BSC Mainnet HTTP: https://bsc-dataseed1.binance.org/
RPC_URL=ws://127.0.0.1:8545
CHAIN_ID=31337

INCINERATOR_ADDRESS=0x...
COMPACTOR_ADDRESS=0x...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
